{
  "lexicon": 1,
  "id": "app.brew-haiku.timer",
  "defs": {
    "main": {
      "type": "record",
      "description": "A brewing timer recipe with steps and configuration",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["name", "vessel", "brewType", "steps", "createdAt"],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 100,
            "description": "Recipe name (e.g., 'My V60 Recipe')"
          },
          "vessel": {
            "type": "string",
            "maxLength": 100,
            "description": "Brewing vessel (e.g., 'Hario V60', 'Gaiwan', 'French Press')"
          },
          "brewType": {
            "type": "string",
            "knownValues": ["coffee", "tea"],
            "description": "Primary beverage category"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "ref",
              "ref": "#step"
            },
            "maxLength": 20,
            "description": "Ordered brewing steps"
          },
          "notes": {
            "type": "string",
            "maxLength": 500,
            "description": "Optional brewing notes or tips"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "Timestamp when the timer was created"
          }
        }
      }
    },
    "step": {
      "type": "object",
      "description": "A single step in a brewing recipe",
      "required": ["action", "stepType"],
      "properties": {
        "action": {
          "type": "string",
          "maxLength": 200,
          "description": "Step instruction (e.g., 'Pour water in circles', 'Steep tea', 'Grind coffee')"
        },
        "stepType": {
          "type": "string",
          "knownValues": ["timed", "indeterminate", "quantity"],
          "description": "Whether step has a fixed duration (timed), user-controlled completion (indeterminate), or prompts the user to enter a quantity (quantity)"
        },
        "durationSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600,
          "description": "Step duration in seconds (for 'timed' steps)"
        },
        "unit": {
          "type": "string",
          "knownValues": ["g", "oz", "ml"],
          "description": "Unit for quantity entry (for 'quantity' steps)"
        },
        "ratioOfStep": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based index of a 'quantity' step to derive this step's quantity from"
        },
        "ratio": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 100,
          "description": "Multiplier applied to the referenced quantity step's value (e.g., 16 means 16x the quantity)"
        }
      }
    }
  }
}
