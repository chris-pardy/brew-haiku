{
  "lexicon": 1,
  "id": "app.brew-haiku.listBrews",
  "defs": {
    "main": {
      "type": "query",
      "description": "List brew sessions. If a DID is provided, lists that user's brews; otherwise lists the authenticated user's brews.",
      "parameters": {
        "type": "params",
        "properties": {
          "did": {
            "type": "string",
            "format": "did",
            "description": "DID of the user whose brews to list"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["brews"],
          "properties": {
            "brews": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#brewView"
              }
            },
            "cursor": {
              "type": "string"
            }
          }
        }
      }
    },
    "brewView": {
      "type": "object",
      "required": ["uri", "did", "timerUri", "createdAt"],
      "properties": {
        "uri": {
          "type": "string",
          "format": "at-uri"
        },
        "did": {
          "type": "string",
          "format": "did"
        },
        "timerUri": {
          "type": "string",
          "format": "at-uri"
        },
        "postUri": {
          "type": "string",
          "format": "at-uri"
        },
        "stepValues": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "app.brew-haiku.brew#stepValue"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "datetime"
        }
      }
    }
  }
}
