{
  "lexicon": 1,
  "id": "app.brew-haiku.createTimer",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Create a new timer record in the authenticated user's repo and automatically save it to their collection. Creates both the timer record and a savedTimer record in the user's PDS.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["name", "vessel", "brewType", "steps"],
          "properties": {
            "name": {
              "type": "string",
              "maxLength": 100
            },
            "vessel": {
              "type": "string",
              "maxLength": 100
            },
            "brewType": {
              "type": "string",
              "knownValues": ["coffee", "tea"]
            },
            "steps": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "app.brew-haiku.timer#step"
              },
              "maxLength": 20
            },
            "notes": {
              "type": "string",
              "maxLength": 500
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["uri", "cid"],
          "properties": {
            "uri": {
              "type": "string",
              "format": "at-uri"
            },
            "cid": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
